# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------
# Public — safe to ship to the browser. Used by the client waitlist insert
# and the server-side `get_waitlist_count` RPC call.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — only needed if you want server-only operations beyond the
# public RPC (none in v1). The waitlist count now goes through the
# `get_waitlist_count` SECURITY DEFINER function, so the anon key is enough.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Analytics (optional — pick AT MOST ONE provider)
# ---------------------------------------------------------------------------
# Provider precedence (the first match wins, others are ignored):
#   1. NEXT_PUBLIC_POSTHOG_KEY      → PostHog
#   2. NEXT_PUBLIC_UMAMI_WEBSITE_ID → Umami
#   3. NEXT_PUBLIC_PLAUSIBLE_DOMAIN → Plausible
# Leave all three unset to disable analytics entirely (no-op).

# --- Option A: PostHog -----------------------------------------------------
# Get your project key from https://app.posthog.com → Project Settings.
# NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional — defaults to https://us.i.posthog.com. Use https://eu.i.posthog.com
# for EU-region projects.
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Option B: Umami -------------------------------------------------------
# Get your website ID from your Umami dashboard. Self-hosted users can
# override the script URL with NEXT_PUBLIC_UMAMI_SCRIPT_URL (defaults to
# Umami Cloud's https://cloud.umami.is/script.js).
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# --- Option C: Plausible ---------------------------------------------------
# Use your real production domain (no protocol, no trailing slash).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=palate.app
