# Copy to .env and fill in your values.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the app.
# Do NOT put secret keys here — only the Supabase URL and anon key,
# which are safe to expose because Row Level Security protects the data.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
